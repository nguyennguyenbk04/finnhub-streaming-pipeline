        "x": 0,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 2
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "hadesarchitect-cassandra-datasource",
            "uid": "cassandra-trading"
          },
          "datasourceId": 1,
          "queryType": "query",
          "rawQuery": true,
          "refId": "A",
          "target": "SELECT trade_time, price FROM trading.latest_price WHERE symbol='BINANCE:BTCUSDT'"
