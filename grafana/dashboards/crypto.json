      "id": 9,
      "title": "Latest Trades \u2014 $symbol",
      "type": "table",
      "gridPos": {
        "x": 12,
        "y": 28,
        "w": 12,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "price"
            },
            "properties": [
              {
                "id": "unit",
                "value": "currencyUSD"
              },
              {
                "id": "decimals",
                "value": 2
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "volume"
            },
            "properties": [
              {
                "id": "decimals",
                "value": 6
              }
            ]
          }
        ]
      },
