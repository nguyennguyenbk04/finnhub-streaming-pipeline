            "type": "hadesarchitect-cassandra-datasource",
            "uid": "cassandra-trading"
          },
          "datasourceId": 1,
          "queryType": "query",
          "rawQuery": true,
          "refId": "A",
          "target": "SELECT window_start, open_price, high_price, low_price, close_price, total_volume, trade_count FROM trading.trades_agg_1m WHERE symbol='$symbol' AND trade_date=toDate(now()) ORDER BY window_start DESC LIMIT 30"
        }
      ]
    },
