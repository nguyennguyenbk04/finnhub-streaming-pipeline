        {
          "datasource": {
            "type": "hadesarchitect-cassandra-datasource",
            "uid": "cassandra-trading"
          },
          "datasourceId": 1,
          "queryType": "query",
          "rawQuery": true,
          "refId": "A",
          "target": "SELECT trade_time, price, volume FROM trading.trades WHERE symbol='$symbol' AND trade_date=toDate(now()) AND trade_time>$__timeFrom AND trade_time<$__timeTo ORDER BY trade_time DESC LIMIT 15"
        }
      ]
